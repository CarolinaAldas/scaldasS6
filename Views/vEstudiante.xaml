<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="scaldasS6.Views.vEstudiante"
             Title="Estudiantes">
    <VerticalStackLayout Padding="10">

        <!-- Encabezado tabla -->
        <Grid ColumnDefinitions="*,*,*,*" BackgroundColor="Yellow">
            <Label Grid.Column="0" Text="Codigo"   FontAttributes="Bold" HorizontalOptions="Center"/>
            <Label Grid.Column="1" Text="Nombre"   FontAttributes="Bold" HorizontalOptions="Center"/>
            <Label Grid.Column="2" Text="Apellido" FontAttributes="Bold" HorizontalOptions="Center"/>
            <Label Grid.Column="3" Text="Edad"     FontAttributes="Bold" HorizontalOptions="Center"/>
        </Grid>

        <!-- Filas de datos -->
        <ListView x:Name="listaEstudiante"
                  ItemSelected="listaEstudiantes_ItemSelected">
            <ListView.ItemTemplate>
                <DataTemplate>
                    <ViewCell>
                        <Grid ColumnDefinitions="*,*,*,*" Padding="0,5">
                            <Label Grid.Column="0" Text="{Binding codigo}"   HorizontalOptions="Center"/>
                            <Label Grid.Column="1" Text="{Binding nombre}"   HorizontalOptions="Center"/>
                            <Label Grid.Column="2" Text="{Binding apellido}" HorizontalOptions="Center"/>
                            <Label Grid.Column="3" Text="{Binding edad}"     HorizontalOptions="Center"/>
                        </Grid>
                    </ViewCell>
                </DataTemplate>
            </ListView.ItemTemplate>
        </ListView>

        <!-- Botón agregar -->
        <Button Text="Agregar estudiante"
                BackgroundColor="#5B4FCF"
                TextColor="White"
                CornerRadius="8"
                Margin="0,10,0,0"
                Clicked="btnAgregar_Clicked"/>

    </VerticalStackLayout>
</ContentPage>